---
const testimonials = [
  {
    quote: "Seb transformed our old website into something modern and blazing fast. Our enquiries have doubled since the relaunch.",
    name: "Sarah Mitchell",
    role: "Owner, Perth Café Co.",
    initials: "SM",
    stars: 5,
  },
  {
    quote: "Professional, responsive, and genuinely cares about delivering results. He went above and beyond to make sure everything was pixel-perfect.",
    name: "James Cooper",
    role: "Director, Cooper Consulting",
    initials: "JC",
    stars: 5,
  },
  {
    quote: "Our e-commerce site was slow and losing sales. Seb optimized everything and our page speed score jumped from 40 to 95. Highly recommend.",
    name: "Emily Zhang",
    role: "Founder, Bloom Beauty",
    initials: "EZ",
    stars: 5,
  },
];
---

<section id="testimonials" class="py-24 bg-secondary relative overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1.5 bg-white/10 text-white/80 text-sm font-semibold rounded-full mb-4 tracking-wide uppercase border border-white/10">
        Testimonials
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        What Clients <span class="text-accent">Say</span>
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div class={`bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 relative group hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:shadow-lg reveal reveal-delay-${i + 1}`}>
          <!-- Quote mark -->
          <svg class="absolute top-6 right-6 w-10 h-10 text-white/5 group-hover:text-white/10 transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391C0 7.905 3.748 4.039 9 3l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/>
          </svg>

          <!-- Star rating -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-white/70 text-sm leading-relaxed mb-6 italic relative z-10">
            "{t.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-full flex items-center justify-center text-white text-sm font-bold shadow-md">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-white/50">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
