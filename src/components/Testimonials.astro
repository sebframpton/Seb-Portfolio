---
const testimonials = [
  {
    quote: "Seb transformed our old website into something modern and blazing fast. Our enquiries have doubled since the relaunch.",
    name: "Sarah Mitchell",
    role: "Owner, Perth Café Co.",
    initials: "SM",
  },
  {
    quote: "Professional, responsive, and genuinely cares about delivering results. He went above and beyond to make sure everything was pixel-perfect.",
    name: "James Cooper",
    role: "Director, Cooper Consulting",
    initials: "JC",
  },
  {
    quote: "Our e-commerce site was slow and losing sales. Seb optimized everything and our page speed score jumped from 40 to 95. Highly recommend.",
    name: "Emily Zhang",
    role: "Founder, Bloom Beauty",
    initials: "EZ",
  },
];
---

<section id="testimonials" class="py-24 bg-background relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-sm font-semibold rounded-full mb-4 tracking-wide uppercase">
        Testimonials
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-secondary tracking-tight">
        What Clients <span class="text-primary">Say</span>
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-surface rounded-2xl p-8 border border-border/60 relative group hover:border-primary/20 transition-all duration-300 hover:shadow-lg">
          <!-- Quote mark -->
          <svg class="absolute top-6 right-6 w-10 h-10 text-primary/10 group-hover:text-primary/20 transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391C0 7.905 3.748 4.039 9 3l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/>
          </svg>

          <!-- Quote text -->
          <p class="text-text-light text-sm leading-relaxed mb-6 italic relative z-10">
            "{t.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-primary to-primary-dark rounded-full flex items-center justify-center text-white text-sm font-bold shadow-md">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold text-secondary">{t.name}</p>
              <p class="text-xs text-text-light">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
