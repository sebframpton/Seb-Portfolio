---
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Animated Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-secondary via-secondary-light to-primary" style="background-size: 400% 400%; animation: gradient-shift 15s ease infinite;"></div>

  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent/15 rounded-full blur-3xl animate-float animation-delay-300"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-light/10 rounded-full blur-3xl"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="animate-fade-up inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 border border-white/20 rounded-full text-white/90 text-sm font-medium mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
      Available for new projects
    </div>

    <!-- Heading -->
    <h1 class="animate-fade-up animation-delay-100 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight tracking-tight">
      Building Websites
      <br />
      <span class="bg-gradient-to-r from-accent via-amber-300 to-accent bg-clip-text text-transparent">
        That Convert
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-up animation-delay-200 mt-6 text-lg sm:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
      Fast, responsive websites that convert visitors into customers — built by a Perth developer who cares about your business results.
    </p>

    <!-- CTA Buttons -->
    <div class="animate-fade-up animation-delay-300 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#contact" class="group px-8 py-3.5 bg-accent hover:bg-accent-dark text-secondary font-bold rounded-full transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 flex items-center gap-2">
        Start a Project
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#projects" class="px-8 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-full transition-all border border-white/20 backdrop-blur-sm hover:-translate-y-1">
        View My Work
      </a>
    </div>

    <!-- Tech Stack -->
    <div class="animate-fade-up animation-delay-500 mt-16 flex flex-wrap items-center justify-center gap-6 text-white/50 text-sm">
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.564-2.438L1.5 0zm7.031 9.75l-.232-2.718 10.059.003.014-.004.071-.757.071-.757.018-.189H6.248l.018.205.232 2.608.013.144h6.984l-.292 3.063-1.2.324-1.212-.337-.078-.91H8.543l.153 1.79 2.803.756 2.802-.756.342-3.615.024-.253.006-.06H8.531z"/></svg>
        HTML
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.565-2.438L1.5 0zm17.09 4.413L5.41 4.41l.213 2.622 10.125.002-.255 2.716h-6.64l.24 2.573h6.182l-.366 3.523-2.91.804-2.956-.81-.188-2.11h-2.61l.29 3.855L12 19.002l5.355-1.12.927-13.47z"/></svg>
        CSS
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0h24v24H0V0zm22.034 18.276c-.175-1.095-.888-2.015-3.003-2.873-.736-.345-1.554-.585-1.797-1.14-.091-.33-.105-.51-.046-.705.15-.646.915-.84 1.515-.66.39.12.75.42.976.9 1.034-.676 1.034-.676 1.755-1.125-.27-.42-.405-.6-.586-.78-.63-.705-1.469-1.065-2.834-1.034l-.705.089c-.676.165-1.32.525-1.71 1.005-1.14 1.291-.811 3.541.569 4.471 1.365 1.02 3.361 1.244 3.616 2.205.24 1.17-.87 1.545-1.966 1.41-.811-.18-1.26-.586-1.755-1.336l-1.83 1.051c.21.48.45.689.81 1.109 1.74 1.756 6.09 1.666 6.871-1.004.029-.09.24-.705.074-1.65l.046.067zm-8.983-7.245h-2.248c0 1.938-.009 3.864-.009 5.805 0 1.232.063 2.363-.138 2.711-.33.689-1.18.601-1.566.48-.396-.186-.588-.45-.82-.876-.063-.12-.11-.194-.127-.194l-1.825 1.125c.305.63.75 1.172 1.324 1.517.855.51 2.004.675 3.207.405.783-.226 1.458-.691 1.811-1.411.51-.93.402-2.07.397-3.346.012-2.054 0-4.109 0-6.179l.004-.037z"/></svg>
        JavaScript
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M21.469 6.825c.84 1.537 1.318 3.3 1.318 5.175 0 3.979-2.156 7.456-5.363 9.325-.477-.55-1.14-.975-1.907-1.195l-.186-.06c.344-.645.538-1.378.538-2.155 0-.372-.044-.735-.128-1.082 2.09-1.455 3.464-3.876 3.464-6.633 0-1.37-.346-2.66-.954-3.787l.218-.088c.727-.295 1.357-.787 1.834-1.424l.098-.13.067.054zm-2.16-2.49c-.507.52-.869 1.188-1.023 1.932l-.043.218c-1.478-.97-3.247-1.535-5.147-1.535-1.63 0-3.164.41-4.504 1.131l-.086-.11c-.49-.634-1.157-1.12-1.923-1.397C8.53 2.566 10.912 1.5 13.546 1.5c2.252 0 4.316.813 5.913 2.16l-.15.175zm-9.421.478c-.394.776-.62 1.65-.62 2.58 0 .323.027.64.08.949-2.276 1.4-3.822 3.886-3.822 6.733 0 1.143.244 2.228.682 3.209l-.174.077c-.755.334-1.38.884-1.815 1.567C2.297 17.397 1.213 14.81 1.213 12c0-3.384 1.595-6.395 4.075-8.326l.125.08c.596.381 1.277.616 2.006.706l.469.053zm3.649 1.687c3.868 0 7.002 3.134 7.002 7.002s-3.134 7.002-7.002 7.002c-3.868 0-7.002-3.134-7.002-7.002s3.134-7.002 7.002-7.002z"/></svg>
        WordPress
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M7.01 10.207h-.944l-.515 2.648h.838c.556 0 .97-.105 1.242-.314.272-.21.455-.559.55-1.049.092-.47.05-.802-.124-.995-.175-.193-.523-.29-1.047-.29zM12 5.688C5.373 5.688 0 8.514 0 12s5.373 6.313 12 6.313S24 15.486 24 12c0-3.486-5.373-6.312-12-6.312zm-3.26 7.451c-.261.25-.575.438-.917.551-.336.108-.765.164-1.285.164H5.357l-.327 1.681H3.652l1.23-6.326h2.65c.797 0 1.378.209 1.744.628.366.418.476 1.002.33 1.752a2.836 2.836 0 01-.367.899c-.186.29-.422.543-.7.75l.001.001zm4.478-1.033l-.49 2.513c-.06.305-.033.516.08.633.112.117.327.176.645.176.264 0 .504-.05.72-.152.217-.1.39-.247.52-.44.13-.192.223-.42.278-.683l.49-2.513h1.378l-.49 2.513c-.155.793-.505 1.394-1.05 1.803-.546.41-1.224.614-2.035.614-.836 0-1.42-.193-1.753-.578-.334-.385-.414-.95-.24-1.693l.49-2.647-.004-.012h1.378l.083-.534zm7.727 3.074c-.56.418-1.31.627-2.248.627h-2.567l1.23-6.326h2.549c.896 0 1.497.225 1.806.674.308.449.345 1.116.113 2.002a4.236 4.236 0 01-.442 1.158c-.217.37-.483.691-.798.963l.357-.098z"/></svg>
        PHP
      </span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
